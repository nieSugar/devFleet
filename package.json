{
  "name": "devfleet",
  "private": true,
  "version": "2.1.8",
  "description": "用于快速启动项目与编辑器",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "sync:version": "tsx scripts/sync-app-version.ts",
    "sync:antd-css": "tsx scripts/generate-antd-static-css.tsx",
    "build": "pnpm sync:version && pnpm sync:antd-css && tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "pnpm sync:version && tauri dev",
    "tauri:build": "pnpm sync:version && tauri build",
    "i18n:translate": "tsx scripts/translate-locales.ts",
    "i18n:translate:dry": "tsx scripts/translate-locales.ts --dry-run",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"scripts/**/*.{ts,tsx}\"",
    "icon": "tauri icon ./logo.png"
  },
  "author": {
    "name": "nieSugar",
    "email": "niesuger@gmail.com"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.14.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/nieSugar/devFleet"
  },
  "dependencies": {
    "@ant-design/cssinjs": "^1.24.0",
    "@ant-design/icons": "^6.0.0",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/plus-jakarta-sans": "^5.2.8",
    "@lobehub/icons": "^5.2.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-autostart": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "antd": "^5.27.1",
    "i18next": "^26.0.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-i18next": "^17.0.2",
    "react-router-dom": "^7.14.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.5.2",
    "@types/react": "^19.1.11",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.57.1",
    "vite": "^7.1.3"
  }
}
