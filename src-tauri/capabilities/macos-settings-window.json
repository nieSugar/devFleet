{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "macos-settings-window",
  "description": "仅在 macOS 上为设置窗口开放关闭、语言同步和标题栏主题同步能力",
  "windows": ["settings"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:app:allow-set-app-theme"
  ],
  "platforms": ["macOS"]
}
